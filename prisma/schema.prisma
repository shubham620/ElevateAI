// prisma/schema.prisma
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  password      String
  role          String    @default("EMPLOYEE")
  department    String?
  avatar        String?
  
  // Manager relationship
  managerId     String?
  manager       User?     @relation("ManagerToEmployee", fields: [managerId], references: [id], onDelete: SetNull)
  employees     User[]    @relation("ManagerToEmployee")
  
  // Goals
  goals         Goal[]
  
  // Notifications
  notifications Notification[]
  
  // Activity logs
  activities    ActivityLog[]
  
  // Goal comments
  goalComments  GoalComment[]
  
  // AI Insights
  aiInsights    AIInsight[]
  
  // Check-ins
  checkins      QuarterlyCheckin[]
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([email])
  @@index([role])
  @@index([department])
}

model Goal {
  id                String    @id @default(cuid())
  title             String
  description       String
  thrustArea        String
  kpiType           String
  target            Float
  progress          Float     @default(0)
  status            String    @default("DRAFT")
  approvalStatus    String    @default("PENDING")
  weightage         Float
  deadline          DateTime
  locked            Boolean   @default(false)
  
  employeeId        String
  employee          User      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  
  sharedGoalId      String?
  sharedGoal        Goal?     @relation("SharedGoals", fields: [sharedGoalId], references: [id], onDelete: SetNull)
  linkedGoals       Goal[]    @relation("SharedGoals")
  
  checkins          QuarterlyCheckin[]
  comments          GoalComment[]
  activities        ActivityLog[]
  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([employeeId])
  @@index([status])
  @@index([approvalStatus])
  @@index([deadline])
}

model GoalComment {
  id        String   @id @default(cuid())
  content   String
  goalId    String
  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([goalId])
  @@index([userId])
}

model QuarterlyCheckin {
  id              String   @id @default(cuid())
  goalId          String
  goal            Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
  
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  quarter         String
  year            Int
  achievement     String
  progress        Float
  status          String
  managerComment  String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([goalId])
  @@index([userId])
  @@index([quarter])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  type      String
  message   String
  read      Boolean  @default(false)
  
  relatedId String?
  
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([read])
}

model ActivityLog {
  id        String   @id @default(cuid())
  action    String
  
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  goalId    String?
  goal      Goal?    @relation(fields: [goalId], references: [id], onDelete: Cascade)
  
  oldValue  String?
  newValue  String?
  
  metadata  String?
  
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([goalId])
  @@index([timestamp])
}

model AIInsight {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  insightType String
  title       String
  content     String
  
  metadata    String?
  
  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([insightType])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  
  userId    String?
  changes   String
  
  timestamp DateTime @default(now())

  @@index([action])
  @@index([timestamp])
}
